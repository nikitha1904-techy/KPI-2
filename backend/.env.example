# Full LLM/API mode
# This version ALWAYS calls the configured LLM/API.
# There is no deterministic scoring mode and no reference workbook copy mode.
# Copy this file to backend/.env and fill exactly one provider section.

# Option 1: OpenAI or OpenAI-compatible endpoint
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Option 2: Azure OpenAI
# To use Azure, comment the OpenAI provider above and uncomment this provider line.
# LLM_PROVIDER=azure_openai
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=

# Pipeline settings
TOP_N=5
LLM_TEMPERATURE=0.1
USE_REFERENCE_FOR_SAMPLE=false
